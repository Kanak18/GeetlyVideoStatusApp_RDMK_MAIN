<?xml version="1.0" encoding="utf-8" ?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#55000000"
    android:tag="layout/dialog_download_file_0">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="30.0dip"
        android:layout_marginRight="30.0dip"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="5.0dip"
        app:cardElevation="0.100000024dip">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible" >
            <ImageView
                android:layout_marginTop="@dimen/_10sdp"
                android:src="@drawable/premium_header_one"
                android:layout_height="60dp"
                android:layout_width="match_parent"
                />
            <ImageView
                android:src="@drawable/premium_header_two"
                android:layout_width="match_parent"
                android:layout_height="210dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1"
                android:visibility="visible" >

                <ImageView
                    android:src="@drawable/btncancel"
                    android:layout_weight="0.5"
                    android:id="@+id/btnNo"
                    android:layout_width="0dp"
                    android:layout_height="110dp"/>

                <ImageView
                    android:src="@drawable/premium_btnremove"
                    android:id="@+id/btnYes"
                    android:layout_weight="0.5"
                    android:layout_width="0dp"
                    android:layout_height="110dp"/>

            </LinearLayout>
        </LinearLayout>



    </androidx.cardview.widget.CardView>
</FrameLayout>
